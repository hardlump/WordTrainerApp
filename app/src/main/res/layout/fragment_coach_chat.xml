<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@color/screen_bg"
    android:padding="12dp">

    <!-- Прогресс урока (виден только в режиме урока) -->
    <LinearLayout
        android:id="@+id/lessonProgressPanel"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:layout_marginBottom="8dp"
        android:visibility="gone">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal">

            <TextView
                android:id="@+id/lessonProgressLabel"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="@string/coach_lesson_progress"
                android:textColor="@color/text_secondary"
                android:textSize="12sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/lessonProgressPercent"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textColor="@color/text_secondary"
                android:textSize="12sp" />
        </LinearLayout>

        <com.google.android.material.progressindicator.LinearProgressIndicator
            android:id="@+id/lessonProgressBar"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp"
            app:trackCornerRadius="4dp"
            app:trackThickness="8dp"
            app:indicatorColor="@color/accent_teal"
            app:trackColor="@color/text_secondary" />
    </LinearLayout>

    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/messagesRecycler"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:clipToPadding="false"
        android:paddingBottom="8dp" />

    <TextView
        android:id="@+id/thinkingText"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginStart="8dp"
        android:text="@string/coach_thinking"
        android:textColor="@color/text_secondary"
        android:textSize="12sp"
        android:visibility="gone" />

    <com.google.android.material.progressindicator.LinearProgressIndicator
        android:id="@+id/thinkingBar"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginBottom="4dp"
        android:indeterminate="true"
        app:trackThickness="2dp"
        android:visibility="gone" />

    <!-- Кнопка завершения урока (в конце урока вместо ввода) -->
    <com.google.android.material.button.MaterialButton
        android:id="@+id/finishLessonBtn"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="8dp"
        android:text="@string/coach_finish_lesson"
        app:backgroundTint="@color/accent_correct"
        android:textColor="@color/white"
        app:cornerRadius="24dp"
        android:visibility="gone" />

    <!-- Панель ввода -->
    <LinearLayout
        android:id="@+id/inputPanel"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:layout_marginTop="8dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical">

            <EditText
                android:id="@+id/messageInput"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:hint="@string/coach_chat_hint"
                android:inputType="textCapSentences|textMultiLine"
                android:maxLines="4"
                android:importantForAutofill="no"
                android:textColor="@color/text_primary"
                android:textColorHint="@color/text_secondary" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/sendBtn"
                style="@style/Widget.MaterialComponents.Button.Icon"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="4dp"
                android:insetTop="0dp"
                android:insetBottom="0dp"
                app:icon="@drawable/ic_send"
                app:iconTint="@color/white"
                app:iconGravity="textStart"
                app:iconPadding="0dp"
                app:backgroundTint="@color/brand_primary"
                app:cornerRadius="24dp"
                android:minWidth="0dp"
                android:paddingHorizontal="18dp" />
        </LinearLayout>

        <!-- Кнопка «удерживать, чтобы говорить» -->
        <com.google.android.material.button.MaterialButton
            android:id="@+id/micBtn"
            style="@style/Widget.MaterialComponents.Button.OutlinedButton.Icon"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center_horizontal"
            android:layout_marginTop="8dp"
            android:text="@string/coach_hold_to_speak"
            app:icon="@drawable/ic_mic"
            app:iconTint="@color/accent_speak"
            android:textColor="@color/accent_speak" />
    </LinearLayout>

</LinearLayout>
