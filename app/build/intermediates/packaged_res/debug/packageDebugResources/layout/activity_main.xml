<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#FAF3E0"
    android:padding="20dp">

    <!-- Кнопка импорта файла JSON -->
    <com.google.android.material.button.MaterialButton
        android:id="@+id/importJsonBtn"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="📂 Импорт"
        app:backgroundTint="#7F8C8D"
        android:textColor="#FFFFFF"
        android:textSize="12sp"
        android:paddingStart="12dp"
        android:paddingEnd="12dp"
        android:layout_marginBottom="10dp"
        app:cornerRadius="20dp"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"/>

    <!-- Английское слово фиксировано сверху -->
    <TextView
        android:id="@+id/wordText"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:text="Word"
        android:textSize="28sp"
        android:textStyle="bold"
        android:textColor="#2C3E50"
        android:gravity="center"
        app:layout_constraintTop_toBottomOf="@id/importJsonBtn"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        android:layout_marginTop="10dp"
        android:layout_marginBottom="10dp"/>

    <!-- ScrollView для перевода -->
    <ScrollView
        android:id="@+id/translationScroll"
        android:layout_width="0dp"
        android:layout_height="0dp"
        app:layout_constraintTop_toBottomOf="@id/wordText"
        app:layout_constraintBottom_toTopOf="@id/showTranslationBtn"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <TextView
            android:id="@+id/translationText"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text=""
            android:textSize="24sp"
            android:textColor="#27AE60"
            android:gravity="center"/>
    </ScrollView>

    <!-- Кнопка показать перевод -->
    <com.google.android.material.button.MaterialButton
        android:id="@+id/showTranslationBtn"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:text="Показать перевод"
        app:backgroundTint="#2980B9"
        android:textColor="#FFFFFF"
        app:layout_constraintBottom_toTopOf="@id/speakBtn"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        android:layout_marginBottom="10dp"/>

    <!-- Кнопка озвучивания слова -->
    <com.google.android.material.button.MaterialButton
        android:id="@+id/speakBtn"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:text="🔊 Произнести"
        app:backgroundTint="#3498DB"
        android:textColor="#FFFFFF"
        app:layout_constraintBottom_toTopOf="@id/switchSourceBtn"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        android:layout_marginBottom="10dp"/>

    <!-- Кнопка переключения источника -->
    <com.google.android.material.button.MaterialButton
        android:id="@+id/switchSourceBtn"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:text="Мои слова"
        app:backgroundTint="#E67E22"
        android:textColor="#FFFFFF"
        app:layout_constraintBottom_toTopOf="@id/bottomButtonsLayout"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        android:layout_marginBottom="10dp"/>

    <!-- Нижняя панель с предыдущим и следующим -->
    <LinearLayout
        android:id="@+id/bottomButtonsLayout"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        android:layout_marginBottom="20dp">

        <com.google.android.material.button.MaterialButton
            android:id="@+id/prevBtn"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Предыдущее"
            app:backgroundTint="#8E44AD"
            android:textColor="#FFFFFF"
            android:layout_marginEnd="15dp"
            android:paddingStart="20dp"
            android:paddingEnd="20dp"/>

        <com.google.android.material.button.MaterialButton
            android:id="@+id/nextBtn"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Следующее"
            app:backgroundTint="#16A085"
            android:textColor="#FFFFFF"
            android:paddingStart="20dp"
            android:paddingEnd="20dp"/>
    </LinearLayout>

</androidx.constraintlayout.widget.ConstraintLayout>
